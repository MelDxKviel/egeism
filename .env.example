# Copy to .env and adjust. docker-compose reads TELEGRAM_TOKEN from the shell.

# Postgres DSN used by api / worker / ingest / migrate.
DATABASE_URL=postgres://egeism:egeism@localhost:5432/egeism?sslmode=disable

# HTTP listen address for the API.
HTTP_ADDR=:8080

# Redis for asynq (worker + API enqueuer).
REDIS_ADDR=localhost:6379

# Telegram bot token (leave empty to run without the bot; notifications log only).
TELEGRAM_TOKEN=

# Secret for signing session JWTs. CHANGE THIS in any real deployment.
JWT_SECRET=dev-insecure-change-me

# API base URL the bot calls.
API_BASE_URL=http://localhost:8080

# MinIO / S3 for task media.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=egeism-media
MINIO_USE_SSL=false
