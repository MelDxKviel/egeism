# Production environment. On the SERVER: copy to deploy/.env and fill in.
#   cp deploy/.env.prod.example deploy/.env
# docker-compose.prod.yml reads it via `make prod-up` (--env-file deploy/.env).
# Never commit the filled-in deploy/.env.

# ── Domain & TLS ──────────────────────────────────────────────────────────────
# Your domain, pointed at the server's public IP with a DNS A record BEFORE the
# first deploy (Caddy needs it reachable to obtain the Let's Encrypt cert).
DOMAIN=egeism.example.com
# Contact email for Let's Encrypt (expiry notices; required by the ACME account).
ACME_EMAIL=you@example.com

# ── Secrets ───────────────────────────────────────────────────────────────────
# Session-JWT signing key. MUST be a long random string:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# MinIO credentials — CHANGE from the defaults on a public server.
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me-too

# ── Telegram ──────────────────────────────────────────────────────────────────
# Production bot token from @BotFather. Use a SEPARATE token from local dev —
# one token can't long-poll from two places (they'd fight over updates).
TELEGRAM_TOKEN=
# Bot @username (without @) for the account-linking deep link.
TELEGRAM_BOT_USERNAME=

# ── Optional ──────────────────────────────────────────────────────────────────
# Serve media straight from MinIO instead of through the API (see Caddyfile).
# Leave empty to route media via WEB_URL/api/media (works out of the box).
MEDIA_PUBLIC_URL=
# Display timezone for bot/worker timestamps.
TZ=Europe/Moscow
# Fetcher tuning (optional): seconds budget per pull / delay between requests.
# FETCH_DEADLINE=80
# FETCH_DELAY=0.25
