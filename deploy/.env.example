# docker compose reads this automatically as deploy/.env — copy it there:
#   cp deploy/.env.example deploy/.env
#
# Only the variables below are interpolated by docker-compose.yml. Everything
# else (DATABASE_URL, REDIS_ADDR, MinIO creds, ports) has in-compose defaults
# wired for the container network — no need to set them here.

# Secret for signing session JWTs. CHANGE THIS to a long random string.
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Telegram bot token. Leave empty to run the stack without the bot.
# The bot only starts with the `bot` profile:
#   docker compose -f deploy/docker-compose.yml --profile bot up -d
TELEGRAM_TOKEN=

# Bot @username (without @), e.g. egeism_bot. Used to build the account-linking
# deep link (t.me/<username>?start=<code>) shown by the web "Привязать Telegram"
# button. Optional: if empty, the web shows the /link <code> command instead.
TELEGRAM_BOT_USERNAME=

# The content fetcher pulls REAL tasks only (openfipi for информатика, РЕШУ for
# the rest) — there is no demo/mock mode. Tune if a source is slow (optional):
#   FETCH_DEADLINE=80   # max seconds per pull (API call timeout is 90s)
#   FETCH_WORKERS=6     # concurrent РЕШУ requests (sdamgia path)
