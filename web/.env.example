# Copy to web/.env.local and adjust. Vite exposes only VITE_-prefixed vars.

# API origin used by the browser.
# Leave empty for same-origin: `npm run dev` proxies /api to :8080 (see
# vite.config.ts), and the docker build serves the SPA behind nginx which
# proxies /api to the api service. Set this only to hit a remote API directly.
VITE_API_BASE=
